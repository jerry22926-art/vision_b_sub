# This file must be used with "source bin/activate" *from bash*
# you cannot run it directly

deactivate () {
    # reset old environment variables
    if [ -n "${_OLD_VIRTUAL_PATH:-}" ] ; then
        PATH="${_OLD_VIRTUAL_PATH:-}"
        export PATH
        unset _OLD_VIRTUAL_PATH
    fi
    if [ -n "${_OLD_VIRTUAL_PYTHONHOME:-}" ] ; then
        PYTHONHOME="${_OLD_VIRTUAL_PYTHONHOME:-}"
        export PYTHONHOME
        unset _OLD_VIRTUAL_PYTHONHOME
    fi
    if [ -n "${_OLD_VIRTUAL_LD_LIBRARY_PATH:-}" ] ; then
        LD_LIBRARY_PATH="${_OLD_VIRTUAL_LD_LIBRARY_PATH:-}"
        export LD_LIBRARY_PATH
        unset _OLD_VIRTUAL_LD_LIBRARY_PATH
    else
        unset LD_LIBRARY_PATH
    fi
    if [ -n "${_OLD_VIRTUAL_LIBCAMERA_IPA_MODULE_PATH:-}" ] ; then
        LIBCAMERA_IPA_MODULE_PATH="${_OLD_VIRTUAL_LIBCAMERA_IPA_MODULE_PATH:-}"
        export LIBCAMERA_IPA_MODULE_PATH
        unset _OLD_VIRTUAL_LIBCAMERA_IPA_MODULE_PATH
    else
        unset LIBCAMERA_IPA_MODULE_PATH
    fi
    if [ -n "${_OLD_VIRTUAL_LIBCAMERA_IPA_CONFIG_PATH:-}" ] ; then
        LIBCAMERA_IPA_CONFIG_PATH="${_OLD_VIRTUAL_LIBCAMERA_IPA_CONFIG_PATH:-}"
        export LIBCAMERA_IPA_CONFIG_PATH
        unset _OLD_VIRTUAL_LIBCAMERA_IPA_CONFIG_PATH
    else
        unset LIBCAMERA_IPA_CONFIG_PATH
    fi
    if [ -n "${_OLD_VIRTUAL_LIBCAMERA_IPA_PROXY_PATH:-}" ] ; then
        LIBCAMERA_IPA_PROXY_PATH="${_OLD_VIRTUAL_LIBCAMERA_IPA_PROXY_PATH:-}"
        export LIBCAMERA_IPA_PROXY_PATH
        unset _OLD_VIRTUAL_LIBCAMERA_IPA_PROXY_PATH
    else
        unset LIBCAMERA_IPA_PROXY_PATH
    fi

    # This should detect bash and zsh, which have a hash command that must
    # be called to get it to forget past commands.  Without forgetting
    # past commands the $PATH changes we made may not be respected
    if [ -n "${BASH:-}" -o -n "${ZSH_VERSION:-}" ] ; then
        hash -r 2> /dev/null
    fi

    if [ -n "${_OLD_VIRTUAL_PS1:-}" ] ; then
        PS1="${_OLD_VIRTUAL_PS1:-}"
        export PS1
        unset _OLD_VIRTUAL_PS1
    fi

    unset VIRTUAL_ENV
    unset VIRTUAL_ENV_PROMPT
    if [ ! "${1:-}" = "nondestructive" ] ; then
    # Self destruct!
        unset -f deactivate
    fi
}

# unset irrelevant variables
deactivate nondestructive

VIRTUAL_ENV=/home/vitamind/vitamin_d/vitamin_d
export VIRTUAL_ENV

_OLD_VIRTUAL_PATH="$PATH"
PATH="$VIRTUAL_ENV/"bin":$PATH"
export PATH

_OLD_VIRTUAL_LD_LIBRARY_PATH="${LD_LIBRARY_PATH:-}"
LD_LIBRARY_PATH="/home/vitamind/vitamin_d/.rpi-root/usr/lib/aarch64-linux-gnu:/home/vitamind/vitamin_d/.apt-root/usr/lib/aarch64-linux-gnu:/home/vitamind/vitamin_d/.apt-root/lib/aarch64-linux-gnu${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LD_LIBRARY_PATH

_OLD_VIRTUAL_LIBCAMERA_IPA_MODULE_PATH="${LIBCAMERA_IPA_MODULE_PATH:-}"
LIBCAMERA_IPA_MODULE_PATH="/home/vitamind/vitamin_d/.rpi-root/usr/lib/aarch64-linux-gnu/libcamera"
export LIBCAMERA_IPA_MODULE_PATH

_OLD_VIRTUAL_LIBCAMERA_IPA_CONFIG_PATH="${LIBCAMERA_IPA_CONFIG_PATH:-}"
LIBCAMERA_IPA_CONFIG_PATH="/home/vitamind/vitamin_d/.rpi-root/usr/share/libcamera/ipa"
export LIBCAMERA_IPA_CONFIG_PATH

_OLD_VIRTUAL_LIBCAMERA_IPA_PROXY_PATH="${LIBCAMERA_IPA_PROXY_PATH:-}"
LIBCAMERA_IPA_PROXY_PATH="/home/vitamind/vitamin_d/.rpi-root/usr/lib/aarch64-linux-gnu/libcamera"
export LIBCAMERA_IPA_PROXY_PATH

# unset PYTHONHOME if set
# this will fail if PYTHONHOME is set to the empty string (which is bad anyway)
# could use `if (set -u; : $PYTHONHOME) ;` in bash
if [ -n "${PYTHONHOME:-}" ] ; then
    _OLD_VIRTUAL_PYTHONHOME="${PYTHONHOME:-}"
    unset PYTHONHOME
fi

if [ -z "${VIRTUAL_ENV_DISABLE_PROMPT:-}" ] ; then
    _OLD_VIRTUAL_PS1="${PS1:-}"
    PS1='(vitamin_d) '"${PS1:-}"
    export PS1
    VIRTUAL_ENV_PROMPT='(vitamin_d) '
    export VIRTUAL_ENV_PROMPT
fi

# This should detect bash and zsh, which have a hash command that must
# be called to get it to forget past commands.  Without forgetting
# past commands the $PATH changes we made may not be respected
if [ -n "${BASH:-}" -o -n "${ZSH_VERSION:-}" ] ; then
    hash -r 2> /dev/null
fi
